# ── Database ──────────────────────────────────────────
DATABASE_URL="postgresql://hms_user:hms_password@localhost:5432/hms_dev"

# ── Server ────────────────────────────────────────────
NODE_ENV="development"
PORT=3001
API_BASE_URL="http://localhost:3001"

# ── JWT ───────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET="REPLACE_WITH_64_CHAR_RANDOM_STRING"
JWT_REFRESH_SECRET="REPLACE_WITH_DIFFERENT_64_CHAR_RANDOM_STRING"
JWT_ACCESS_EXPIRY="900"          # 15 minutes in seconds
JWT_REFRESH_EXPIRY="604800"      # 7 days in seconds

# ── Encryption (for sensitive fields) ────────────────
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY="REPLACE_WITH_32_BYTE_HEX_STRING"

# ── Redis (optional, for permission caching) ─────────
REDIS_URL="redis://localhost:6379"
REDIS_ENABLED="false"            # set true when Redis available

# ── CORS ──────────────────────────────────────────────
CORS_ORIGINS="http://localhost:3000"

# ── Rate Limiting ─────────────────────────────────────
RATE_LIMIT_WINDOW_MS="900000"    # 15 minutes
RATE_LIMIT_MAX="100"

# ── Email (stub — replace with real provider) ─────────
EMAIL_PROVIDER="stub"            # stub | sendgrid | ses
SENDGRID_API_KEY=""
EMAIL_FROM="noreply@yourhms.com"

# ── SMS (stub) ────────────────────────────────────────
SMS_PROVIDER="stub"              # stub | twilio
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# ── Storage (stub) ────────────────────────────────────
STORAGE_PROVIDER="local"         # local | s3
AWS_S3_BUCKET=""
AWS_REGION=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# ── Security ──────────────────────────────────────────
BANNED_IPS=""                    # comma-separated IPs/CIDRs to block
MAX_JSON_SIZE="500kb"            # max JSON request body size
MAX_URL_SIZE="100kb"             # max URL-encoded body size

# ── Logging ───────────────────────────────────────────
LOG_LEVEL="debug"                # debug | info | warn | error
LOG_FORMAT="pretty"              # pretty | json
