# =============================================================================
# Hotel Management System - Environment Configuration Template
# =============================================================================
# Copy this file to .env and update values for your environment
# Variables marked as REQUIRED have no defaults and must be set

# Environment
NODE_ENV=development

# Server
PORT=3000
HOST=localhost

# API
API_PREFIX=/api
API_VERSION=v1

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info

# CORS
CORS_ORIGIN=http://localhost:3001

# Database
# REQUIRED - PostgreSQL connection string (no default)
DATABASE_URL=postgresql://hms:hms_dev_password@localhost:5432/hotel_management
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_CONNECTION_TIMEOUT=10000
DB_IDLE_TIMEOUT=30000
LOG_QUERIES=false

# JWT Authentication
# REQUIRED - Must be at least 32 characters (no default)
JWT_ACCESS_SECRET=your-access-secret-key-min-32-chars-here
# REQUIRED - Must be at least 32 characters (no default)
JWT_REFRESH_SECRET=your-refresh-secret-key-min-32-chars-here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
PASSWORD_RESET_URL_BASE=http://localhost:3000/reset-password

# Encryption
# REQUIRED - Must be at least 32 characters (no default)
ENCRYPTION_KEY=your-encryption-key-min-32-chars-here

# Resend Email (optional in development/test, required in production for real email delivery)
# RESEND_API_KEY=your-resend-api-key
# RESEND_FROM_EMAIL=noreply@yourhotel.com
# RESEND_WEBHOOK_SECRET=your-resend-webhook-secret

# Redis (optional)
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Super Admin
SUPER_ADMIN_EMAIL=admin@hms.local
SUPER_ADMIN_PASSWORD=SuperAdmin123!@#

# System
SYSTEM_USER_ID=00000000-0000-0000-0000-000000000000

# Maintenance Scheduler
MAINTENANCE_ESCALATION_CHECKER_ENABLED=true
MAINTENANCE_ESCALATION_CHECKER_INTERVAL_MS=300000
MAINTENANCE_ESCALATION_CHECKER_BATCH_SIZE=100
