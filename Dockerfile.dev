# Development Dockerfile with hot reload
FROM node:20-alpine

WORKDIR /app

# Install dependencies
COPY package*.json ./
RUN npm ci

# Generate Prisma client
COPY prisma/schema.prisma prisma/
RUN npx prisma generate

# Copy source files
COPY . .

# Expose port
EXPOSE 3000

# Start with hot reload
CMD ["npm", "run", "dev"]
